# Environment variables for REX Hub
# Copy this file to .env and fill in the actual values

# Server Configuration
# REX_LISTEN=0.0.0.0:3000
# REX_DATA_DIR=./data
# REX_SECRET_KEY=your-secret-key
# REX_STATIC_DIR=./static

# TLS / HTTPS (manual certificate)
# REX_TLS_CERT=/path/to/cert.pem
# REX_TLS_KEY=/path/to/key.pem

# ACME (Let's Encrypt)
# REX_ACME_DOMAIN=hub.example.com
# REX_ACME_EMAIL=admin@example.com
# REX_ACME_STAGING=false

# Logging
RUST_LOG=info
